# Tesseract OCR language(s) — default is Italian + English
# Add more with "+", e.g. "ita+eng+fra". Full list: https://tesseract-ocr.github.io/tessdoc/Data-Files
TESSERACT_LANG=ita+eng

# Notion (get from notion.so/my-integrations)
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_database_id_here

# Server
PORT=3000

# Output directory for local .md files (relative to project root)
OUTPUT_DIR=./output
